# ── MarvelCDB Node API ──────────────────────────────
# Copy this file to .env and fill in your values.

# MySQL (same DB as Symfony)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=symphony_merlin
DB_USER=root
DB_PASS=

# Server
PORT=4000
NODE_ENV=development

# Base URL used to build absolute card URLs (no trailing slash)
BASE_URL=http://127.0.0.1:4000

# Path to the marvelsdb_fanmade_data repository (used for scenario.json)
# Leave unset to auto-detect from the relative sibling directory.
# FANMADE_DATA_PATH=C:/github/marvelsdb_fanmade_data
