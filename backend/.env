# ── MarvelCDB Node API ──────────────────────────────

# MySQL (same DB as Symfony)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=symphony_merlin
DB_USER=root
DB_PASS=

# Server
PORT=4000
NODE_ENV=development

# Base URL used to build absolute card URLs (no trailing slash)
BASE_URL=http://127.0.0.1:4000
# Default locale used when a pack language is not present on the card
DEFAULT_LOCALE=EN
